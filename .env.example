# Vercel Postgres (serverless). Pull these with `vercel env pull` or copy from
# the Vercel dashboard > Storage > your Postgres > .env.local tab.
# Prisma needs a POOLED url for the app and a DIRECT url for migrations.
DATABASE_URL="postgres://USER:PASSWORD@HOST-pooler.REGION.postgres.vercel-storage.com/DB?sslmode=require"
DIRECT_URL="postgres://USER:PASSWORD@HOST.REGION.postgres.vercel-storage.com/DB?sslmode=require"

# Signs the session cookie (HMAC-SHA256). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="replace-with-a-32-byte-hex-string"

# Vercel Blob store for seller-uploaded product photos. Grab this from
# Vercel Dashboard > Storage > <your blob store> > .env.local tab.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_XXXXXXXXXXXXXXXX_YYYYYYYYYYYYYYYY"
